# Copy this file to deploy/.env on the server and edit the values.

APP_ROOT=/opt/wust-algo
APP_USER=acm_tracker

DOMAIN=algo.example.com
NGINX_PORT=8088
NGINX_SITE_NAME=wust-algo

# The backend gateway listens here after running the backend deploy script.
BACKEND_UPSTREAM=127.0.0.1:8080
USER_UPSTREAM=127.0.0.1:8000
CORE_UPSTREAM=127.0.0.1:8001
AGENT_UPSTREAM=127.0.0.1:8002
